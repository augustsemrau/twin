{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Twin",
  "windows": ["main", "capture"],
  "permissions": [
    "core:default",
    "shell:default",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$HOME/twin/**" },
        { "path": "$HOME/twin" }
      ]
    },
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-watch",
    "fs:allow-unwatch"
  ]
}
